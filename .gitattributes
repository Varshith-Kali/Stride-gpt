# Normalize line endings to LF in the repository for cross-platform consistency.
* text=auto eol=lf

# Explicitly mark binary files so Git never tries to diff them.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
